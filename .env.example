# =============================================================================
# WxO Importer/Export/Comparer/Validator v1.0.8 — Environment Configuration
# =============================================================================
# Copy this file to .env in the project root (or alongside scripts) and fill in
# your values. Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your instance URLs and API keys
#
# The toolkit looks for .env at (in order): watson-orchestrate-builder/.env,
# watsonx-orchestrate-devkit/.env, or wxo-toolkit/.env
# Override: ENV_FILE=/path/to/.env ./wxo_exporter_importer.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Per-environment configuration (recommended)
# -----------------------------------------------------------------------------
# Pattern: WXO_URL_<ENV> and WXO_API_KEY_<ENV>
# Use the same <ENV> name as in 'orchestrate env list' (e.g. TZ1, TZ2, PROD).
#
# Example for TZ1 (US-South) and TZ2 (Sydney):
#
WXO_URL_TZ1=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID_TZ1
WXO_API_KEY_TZ1=your-api-key-for-tz1

WXO_URL_TZ2=https://api.au-syd.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID_TZ2
WXO_API_KEY_TZ2=your-api-key-for-tz2

# Add more environments as needed:
# WXO_URL_PROD=...
# WXO_API_KEY_PROD=...

# -----------------------------------------------------------------------------
# Default / single-environment (optional)
# -----------------------------------------------------------------------------
# Used when adding a new orchestrate env without per-env vars, or by other tools.
# WO_ = Watson Orchestrate (legacy naming).
#
# WO_INSTANCE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/xxx
# WO_API_KEY=your-default-api-key

# -----------------------------------------------------------------------------
# IBM Cloud IAM (optional, for token-based auth)
# -----------------------------------------------------------------------------
# IAM_TOKEN_URL=https://iam.cloud.ibm.com/identity/token

# -----------------------------------------------------------------------------
# Default LLM model (optional)
# -----------------------------------------------------------------------------
# Used as preferred model for agents (e.g. groq/openai/gpt-oss-120b).
# Referenced when creating agents or as fallback when agent has no llm.
#
WXO_LLM=groq/openai/gpt-oss-120b

# -----------------------------------------------------------------------------
# Toolkit options (optional)
# -----------------------------------------------------------------------------
# WXO_ROOT=/path/to/WxO                    # Override WxO output dir
# WXO_DEBUG=1                               # Log commands to WxO/logs/wxo_debug_YYYYMMDD.log
# WXO_LOG=1                                 # Same as WXO_DEBUG (alias)
# WXO_TEST_DEBUG=1                          # Verbose progress (test script)
